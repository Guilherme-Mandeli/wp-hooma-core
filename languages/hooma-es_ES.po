#, php-format
msgid "Invalid Manifest: Main file (%s) must contain \"Plugin Name\" and \"Version\" headers."
msgstr "Manifiesto no válido: El archivo principal (%s) debe contener las cabeceras \"Plugin Name\" y \"Version\"."

